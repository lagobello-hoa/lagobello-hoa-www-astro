---
const year = new Date().getFullYear();
---

<footer class="bg-primary-dark text-cream/90">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-heading text-lg text-cream mb-3">Lago Bello HOA</h3>
        <p class="text-sm text-cream/70 leading-relaxed">
          Brownsville's premier lakeside community.
        </p>
        <p class="text-xs text-cream/50 mt-2">
          <a href="https://www.lagobello.com" target="_blank" rel="noopener noreferrer" class="hover:text-cream transition-colors">lagobello.com</a>
        </p>
      </div>

      <div>
        <h3 class="font-heading text-lg text-cream mb-3">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-cream transition-colors">Home</a></li>
          <li><a href="/about/" class="hover:text-cream transition-colors">About</a></li>
          <li><a href="/documents/" class="hover:text-cream transition-colors">Documents</a></li>
          <li><a href="/contact/" class="hover:text-cream transition-colors">Contact</a></li>
          <li><a href="https://app.payhoa.com" target="_blank" rel="noopener noreferrer" class="hover:text-cream transition-colors">Pay Dues ↗</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-heading text-lg text-cream mb-3">Contact</h3>
        <p class="text-sm leading-relaxed mb-2">
          <a href="mailto:board@lagohoa.org" class="hover:text-cream transition-colors">
            board@lagohoa.org
          </a>
        </p>
        <p class="text-xs text-cream/50">
          Brownsville, Texas
        </p>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-cream/20 text-center text-sm text-cream/50">
      &copy; {year} Lago Bello Home Owners Association, Inc. All rights reserved.
    </div>
  </div>
</footer>
