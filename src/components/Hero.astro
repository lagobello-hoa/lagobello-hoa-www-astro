---
interface Props {
  title: string;
  subtitle?: string;
  large?: boolean;
}

const { title, subtitle, large = false } = Astro.props;
---

<section class:list={["relative text-cream overflow-hidden", large ? "bg-primary-dark" : "bg-gradient-to-br from-primary-dark via-primary to-lake"]}>
  {large ? (
    <!-- Large hero with lake illustration -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-b from-primary-dark via-primary/90 to-lake/80"></div>
      <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 200" preserveAspectRatio="none" style="height: 120px;">
        <path d="M0 80 C360 20, 720 140, 1440 60 L1440 200 L0 200Z" fill="#4ab8d6" opacity="0.2" />
        <path d="M0 100 C300 50, 600 150, 1440 80 L1440 200 L0 200Z" fill="#4ab8d6" opacity="0.15" />
        <path d="M0 130 C400 90, 800 170, 1440 110 L1440 200 L0 200Z" fill="#4ab8d6" opacity="0.1" />
      </svg>
      <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 60" preserveAspectRatio="none" style="height: 30px;">
        <path d="M0 30 Q360 0 720 30 T1440 20 L1440 60 L0 60Z" fill="#faf8f2" />
      </svg>
    </div>
  ) : (
    <!-- Standard hero with subtle waves -->
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 800 400" preserveAspectRatio="none">
        <path d="M0 300 Q200 250 400 300 T800 280 V400 H0Z" fill="currentColor" opacity="0.3" />
        <path d="M0 320 Q200 280 400 320 T800 300 V400 H0Z" fill="currentColor" opacity="0.2" />
        <path d="M0 340 Q200 310 400 340 T800 320 V400 H0Z" fill="currentColor" opacity="0.15" />
      </svg>
    </div>
  )}
  <div class:list={["relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center", large ? "py-28 sm:py-36 lg:py-44" : "py-20 sm:py-28"]}>
    <h1 class:list={["font-heading text-cream leading-tight", large ? "text-4xl sm:text-5xl lg:text-7xl mb-6" : "text-4xl sm:text-5xl lg:text-6xl mb-4"]}>
      {title}
    </h1>
    {subtitle && (
      <p class:list={["text-cream/80 max-w-2xl mx-auto leading-relaxed", large ? "text-xl sm:text-2xl" : "text-lg sm:text-xl"]}>
        {subtitle}
      </p>
    )}
  </div>
</section>
