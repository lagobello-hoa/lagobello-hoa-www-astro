---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import BudgetDashboard from "../components/BudgetDashboard.tsx";
---

<BaseLayout title="Budget" description="Lago Bello HOA annual budget — income, expenses, and financial overview.">
  <Hero title="Annual Budget" subtitle="Fiscal Year 2026" />

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12" aria-label="Budget dashboard">
    <p class="text-slate-light mb-8 max-w-3xl">
      In keeping with our commitment to transparency, below is a breakdown of the Association's
      annual budget. All figures are derived from the monthly reports produced by our accounting system.
    </p>
    <BudgetDashboard client:load />
  </section>
</BaseLayout>
