---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import documentsData from "../content/documents.json";

const { documentGroups } = documentsData;
---

<BaseLayout title="Documents" description="Access Lago Bello HOA governing documents, bylaws, plat maps, and community policies.">
  <Hero title="Document Library" subtitle="Access the CC&Rs, bylaws, plat maps, and community policies for Lago Bello Subdivision." />

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16" aria-label="Document library">
    {documentGroups.map((group) => (
      <div class="mb-12 last:mb-0">
        <div class="mb-6 pb-3 border-b border-cream-dark">
          <h2 class="font-heading text-2xl text-primary-dark">{group.title}</h2>
          <p class="text-sm text-slate-light mt-1">{group.description}</p>
        </div>
        <div class="grid gap-4">
          {group.documents.map((doc) => (
            <article class="bg-white rounded-xl p-6 shadow-sm border border-cream-dark hover:shadow-md transition-shadow">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="flex-1">
                  <h3 class="font-heading text-lg text-primary-dark mb-1">{doc.title}</h3>
                  <p class="text-sm text-slate-light mb-2">{doc.description}</p>
                  <time class="text-xs text-slate-light/70" datetime={doc.date}>
                    {new Date(doc.date).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </div>
                <div class="flex gap-3 shrink-0">
                  <a
                    href={`/documents/${doc.slug}/`}
                    class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-cream text-sm font-semibold rounded-lg hover:bg-primary-light transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    View
                  </a>
                  <a
                    href={`/documents/${doc.filename}`}
                    download
                    class="inline-flex items-center gap-2 px-4 py-2 border border-primary text-primary text-sm font-semibold rounded-lg hover:bg-primary/5 transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    Download
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
