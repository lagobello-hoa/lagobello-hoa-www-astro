---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";

const quickLinks = [
  {
    title: "Documents",
    description: "View the CC&Rs, bylaws, plat maps, and community policies.",
    href: "/documents/",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    color: "bg-primary/10 text-primary group-hover:bg-primary group-hover:text-cream",
  },
  {
    title: "About",
    description: "Community info, utilities, guidelines, and how dues work.",
    href: "/about/",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
    color: "bg-sage/20 text-sage group-hover:bg-sage group-hover:text-cream",
  },
  {
    title: "Pay Dues",
    description: "Submit your monthly HOA dues or set up autopay through PayHOA.",
    href: "https://app.payhoa.com",
    icon: "M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z",
    external: true,
    color: "bg-lake/10 text-lake group-hover:bg-lake group-hover:text-cream",
  },
  {
    title: "Contact",
    description: "Get in touch with the HOA board.",
    href: "/contact/",
    icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
    color: "bg-primary-dark/10 text-primary-dark group-hover:bg-primary-dark group-hover:text-cream",
  },
];
---

<BaseLayout title="Home" description="Welcome to Lago Bello — Brownsville's premier lakeside community in South Texas.">
  <Hero
    title="Lago Bello Home Owners Association"
    subtitle="Brownsville's premier lakeside community."
    large
  />

  <!-- Quick Links -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10 pb-16" aria-label="Quick links">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {quickLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener noreferrer" : undefined}
          class="group bg-white rounded-2xl p-6 shadow-md border border-cream-dark hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
        >
          <div class:list={["w-12 h-12 rounded-xl flex items-center justify-center mb-4 transition-colors duration-300", link.color]}>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={link.icon} />
            </svg>
          </div>
          <h2 class="font-heading text-xl text-primary-dark mb-2">
            {link.title}
            {link.external && (
              <svg class="w-4 h-4 inline ml-1 text-slate-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            )}
          </h2>
          <p class="text-sm text-slate-light leading-relaxed">{link.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Welcome -->
  <section class="bg-white border-y border-cream-dark" aria-label="Welcome message">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading text-3xl sm:text-4xl mb-6">Welcome to Lago Bello</h2>
          <p class="text-lg text-slate-light leading-relaxed mb-4">
            Lago Bello is a residential subdivision built around a beautiful common area lake
            in Brownsville, Texas. Our HOA is committed to maintaining the community's common areas,
            preserving property values, and keeping homeowners informed.
          </p>
          <p class="text-lg text-slate-light leading-relaxed mb-6">
            This website is your central resource for governing documents, community guidelines,
            and contact information. We believe in transparency — all CC&Rs, bylaws, and policies
            are available for download in our
            <a href="/documents/" class="text-primary hover:text-primary-light font-semibold">document library</a>.
          </p>
          <a
            href="https://www.lagobello.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-primary hover:text-primary-light font-semibold transition-colors"
          >
            Learn more at lagobello.com
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
        </div>
        <!-- Visual element: lake illustration -->
        <div class="hidden lg:block" aria-hidden="true">
          <svg viewBox="0 0 400 320" class="w-full max-w-sm mx-auto" fill="none">
            <!-- Sky -->
            <rect width="400" height="320" rx="24" fill="#e6f2f7" />
            <!-- Hills -->
            <path d="M0 200 Q100 140 200 180 Q300 220 400 160 V320 H0Z" fill="#a8c4ad" opacity="0.5" />
            <path d="M0 220 Q150 170 250 210 Q350 250 400 200 V320 H0Z" fill="#7c9a82" opacity="0.4" />
            <!-- Lake -->
            <path d="M0 260 Q100 240 200 255 Q300 270 400 250 V320 H0Z" fill="#4ab8d6" opacity="0.3" />
            <path d="M0 275 Q100 260 200 270 Q300 280 400 265 V320 H0Z" fill="#4ab8d6" opacity="0.2" />
            <path d="M0 290 Q100 280 200 287 Q300 294 400 282 V320 H0Z" fill="#4ab8d6" opacity="0.15" />
            <!-- House -->
            <path d="M180 170 L200 150 L220 170 V210 H180Z" fill="#faf8f2" stroke="#1a6b5a" stroke-width="2" />
            <rect x="192" y="185" width="16" height="25" rx="1" fill="#1a6b5a" opacity="0.3" />
            <path d="M175 172 L200 147 L225 172" stroke="#1a6b5a" stroke-width="2.5" fill="none" stroke-linecap="round" />
            <!-- Trees -->
            <path d="M140 210 L150 175 L160 210Z" fill="#1a6b5a" opacity="0.6" />
            <path d="M250 210 L260 180 L270 210Z" fill="#1a6b5a" opacity="0.5" />
            <path d="M280 210 L288 185 L296 210Z" fill="#1a6b5a" opacity="0.4" />
            <!-- Sun -->
            <circle cx="330" cy="100" r="28" fill="#f0c040" opacity="0.3" />
            <circle cx="330" cy="100" r="18" fill="#f0c040" opacity="0.5" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Info Cards -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20" aria-label="Key information">
    <h2 class="font-heading text-3xl sm:text-4xl mb-10 text-center">Key Information</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <article class="bg-white rounded-2xl p-7 shadow-sm border border-cream-dark text-center">
        <div class="w-14 h-14 bg-lake/10 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-lake" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
          </svg>
        </div>
        <h3 class="font-heading text-lg text-primary-dark mb-2">Monthly Dues</h3>
        <p class="text-sm text-slate-light leading-relaxed">
          <strong class="text-primary-dark">$100/mo</strong> lakeside &nbsp;·&nbsp; <strong class="text-primary-dark">$50/mo</strong> all others<br />
          Due on the 1st via
          <a href="https://app.payhoa.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary-light font-semibold">PayHOA</a>.
        </p>
      </article>
      <article class="bg-white rounded-2xl p-7 shadow-sm border border-cream-dark text-center">
        <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h3 class="font-heading text-lg text-primary-dark mb-2">Governing Documents</h3>
        <p class="text-sm text-slate-light leading-relaxed">
          CC&Rs, bylaws, plat maps, and policies in our
          <a href="/documents/" class="text-primary hover:text-primary-light font-semibold">document library</a>.
        </p>
      </article>
      <article class="bg-white rounded-2xl p-7 shadow-sm border border-cream-dark text-center">
        <div class="w-14 h-14 bg-sage/20 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" />
          </svg>
        </div>
        <h3 class="font-heading text-lg text-primary-dark mb-2">Fiber Internet</h3>
        <p class="text-sm text-slate-light leading-relaxed">
          Omni Fiber FTTH available to all 30 lots. Contact Omni Fiber to get connected.
        </p>
      </article>
    </div>
  </section>

  <!-- Announcements -->
  <section class="bg-white border-y border-cream-dark" aria-label="Announcements">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <h2 class="font-heading text-3xl sm:text-4xl mb-10 text-center">Announcements</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <article class="bg-cream rounded-2xl p-8 border border-cream-dark hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-lake/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-lake" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" />
              </svg>
            </div>
            <time class="text-xs text-slate-light/70 font-semibold uppercase tracking-wide">December 2025</time>
          </div>
          <h3 class="font-heading text-lg text-primary-dark mb-2">Omni Fiber Now Available</h3>
          <p class="text-sm text-slate-light leading-relaxed mb-3">
            Next-generation fiber internet is now deployed to all 30 lots with 100% underground infrastructure.
            Contact Omni Fiber directly to set up service.
          </p>
          <a
            href="https://www.lagobello.com/blog/2025/12/10/omni-fiber/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary-light font-semibold transition-colors"
          >
            Read more
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </article>
        <article class="bg-cream rounded-2xl p-8 border border-cream-dark hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
              </svg>
            </div>
            <time class="text-xs text-slate-light/70 font-semibold uppercase tracking-wide">March 2025</time>
          </div>
          <h3 class="font-heading text-lg text-primary-dark mb-2">Section 2 Annexed</h3>
          <p class="text-sm text-slate-light leading-relaxed mb-3">
            The First Amendment to the Declaration was recorded on March 20, 2025, officially
            annexing 18 new residential lots in Section 2. Welcome to all new homeowners!
          </p>
          <a
            href="/documents/first-amendment-2025-annexation/"
            class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary-light font-semibold transition-colors"
          >
            View amendment
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
